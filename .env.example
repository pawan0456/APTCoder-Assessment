# EdTech NLP-to-SQL API Configuration

# Database
DATABASE_PATH=./data/edtech.db

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# OpenAI Configuration (Optional - for LLM-based conversion)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="
# LLM Settings
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=200

# Logging
LOG_LEVEL=INFO

# Development
DEBUG=False
RELOAD=False

# CORS (for frontend integration)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Query Timeout (seconds)
QUERY_TIMEOUT=30

# Database Connection Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
